# ─── Database ───────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:password@localhost:5432/dashly

# ─── App ────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development

# ─── Auth ───────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=7d

# ─── Encryption (for connector configs) ─────────────────────
ENCRYPTION_KEY=change-me-to-32-char-hex-string

# ─── Redis (query cache) ────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── CORS ───────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000
